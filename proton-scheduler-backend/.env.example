# =============================================================================
# SolidScheduler Backend Configuration
# =============================================================================

# Server Configuration
PORT=3001
NODE_ENV=development
BASE_URL=http://localhost:3001

# Session Secret (generate a secure random string for production)
SESSION_SECRET=your-super-secret-session-key-change-in-production

# Redis (optional — enables persistent Solid sessions across restarts)
# REDIS_URL=redis://localhost:6379

# Solid Identity Provider (default: Inrupt's PodSpaces)
# Users can override this when logging in
DEFAULT_SOLID_IDP=https://login.inrupt.com

# Optional: Static Client Credentials
# If you register your app with your Solid IDP, set these
# SOLID_CLIENT_ID=your-client-id
# SOLID_CLIENT_SECRET=your-client-secret

# Email Configuration (SMTP)
SMTP_HOST=127.0.0.1
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-password

# From address for emails
EMAIL_FROM=noreply@your-domain.com

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:3000

# Solid Pod Paths (relative to user's Pod root)
POD_SCHEDULER_PATH=solid-scheduler
POD_AVAILABILITY_FILE=availability.ttl
POD_BOOKINGS_CONTAINER=bookings
POD_PUBLIC_PROFILE=public-profile.ttl
