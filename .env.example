# =============================================================================
# SolidScheduler — Environment Configuration (Self-Hosted)
# =============================================================================
# Copy this file: cp .env.example .env
# Fill in all required values before starting.
# See SELF-HOSTING.md for a step-by-step guide.

# -----------------------------------------------------------------------------
# Core Settings
# -----------------------------------------------------------------------------
NODE_ENV=production
BASE_URL=https://your-domain.com
FRONTEND_URL=https://your-domain.com
SESSION_SECRET=          # Generate: openssl rand -hex 32
# DOMAIN=your-domain.com       # Used by the Caddy reverse proxy (docker-compose.caddy.yml)
# FRONTEND_PORT=127.0.0.1:3000 # Set when using a reverse proxy (Caddy/nginx) so port 80 is free

# -----------------------------------------------------------------------------
# Redis (Session storage)
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379

# -----------------------------------------------------------------------------
# Solid Identity Provider
# -----------------------------------------------------------------------------
# Any Solid OIDC provider works. Options:
#   - https://login.inrupt.com          (Inrupt PodSpaces — hosted)
#   - https://solidcommunity.net        (Community Solid Server — hosted)
#   - http://localhost:3000             (Self-hosted Community Solid Server)
DEFAULT_SOLID_IDP=https://login.inrupt.com

# -----------------------------------------------------------------------------
# Email (SMTP — any provider)
# -----------------------------------------------------------------------------
SMTP_HOST=127.0.0.1
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@your-domain.com

# -----------------------------------------------------------------------------
# CalDAV Calendar Sync (optional)
# -----------------------------------------------------------------------------
# Sync bookings to an external CalDAV calendar (Nextcloud, Radicale, etc.).
# If you're running Nextcloud, the URL is typically:
#   https://your-nextcloud.com/remote.php/dav/calendars/USERNAME/CALENDAR_NAME/
#
CALDAV_SERVER_URL=
CALDAV_USERNAME=
CALDAV_PASSWORD=
CALDAV_CALENDAR_NAME=
CALDAV_ENABLED=false
